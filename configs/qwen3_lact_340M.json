{
    "architectures": ["LaCTForCausalLM"],
    "model_type": "lact_swiglu",
  
    "vocab_size": 151936,
    "bos_token_id": 151643,
    "eos_token_id": 151643,
    "tie_word_embeddings": true,
  
    "hidden_size": 1024,
    "num_hidden_layers": 24,
    "intermediate_size": 2816,
    "hidden_act": "swish",
  
    "num_attn_heads": 16,
    "num_lact_heads": 4,
  
    "max_position_embeddings": 40960,
    "rope_theta": 1000000.0,
  
    "window_size": 2048,
    "lact_chunk_size": 1024,
    "use_sliding_window": true,
  
    "attention_bias": false,
    "attention_dropout": 0.0,
    "initializer_range": 0.02,
    "norm_eps": 1e-6,
    "torch_dtype": "bfloat16",
  
    "inter_multi": 1,
    "qkv_bias": false,
    "attn_qk_norm": false,
    "qkv_silu": true,
    "use_muon": true,
    "lr_dim": 1,
    "lr_parameterization": "mamba",
    "learnable_ttt_scale": true,
    "ttt_inner_steps": 4,
    "use_momentum": true,
    "w0_w2_low_rank": 32,
    "fw_init_gain": 0.5,
  
    "fuse_norm": true,
    "last_layer_fuse_norm": false,
    "fuse_cross_entropy": true,
    "use_fused_kernel": false,
    "use_cache": true
  }

